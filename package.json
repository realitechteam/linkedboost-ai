{
  "name": "linkedboost-ai",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@linkedboost/web",
    "dev:extension": "npm run dev --workspace=@linkedboost/extension",
    "build:web": "npm run build --workspace=@linkedboost/web",
    "build:extension": "npm run build --workspace=@linkedboost/extension",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css}\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  }
}
