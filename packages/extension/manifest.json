{
    "manifest_version": 3,
    "name": "LinkedBoost AI",
    "version": "1.0.0",
    "description": "AI-powered LinkedIn assistant for smart replies, post writing, and profile optimization",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "LinkedBoost AI"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "http://localhost:3001/*"
    ],
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/*",
                "https://linkedin.com/*"
            ],
            "js": [
                "src/content/index.tsx"
            ],
            "css": [
                "src/content/styles.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "https://www.linkedin.com/*",
                "https://linkedin.com/*"
            ]
        }
    ]
}