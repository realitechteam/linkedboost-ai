// Prisma Schema for LinkedBoost AI
// Database: SQLite (local development)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model - linked to OAuth providers
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  linkedinId    String?   @unique
  role          String    @default("USER") // USER, ADMIN, SUPERADMIN

  // Relations
  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  profiles      LinkedInProfile[]
  posts         PostDraft[]
  jobMatches    JobMatch[]
  usageRecords  UsageRecord[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// UserRole values: USER, ADMIN, SUPERADMIN (stored as String for SQLite)

// NextAuth Account model for OAuth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth Verification Token
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Subscription model for billing
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan      String     @default("FREE") // FREE, PRO, PREMIUM
  status    String     @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE, TRIALING
  profileLimit Int     @default(1) // FREE=1, PRO=5, PREMIUM=unlimited(-1)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Plan values: FREE, PRO, PREMIUM
// SubscriptionStatus values: ACTIVE, CANCELLED, PAST_DUE, TRIALING

// LinkedIn Profile data - supports multiple profiles per user
model LinkedInProfile {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  linkedInId String   // LinkedIn's unique user identifier (from URL or profile)
  profileUrl String
  name       String?
  headline   String?
  about      String?
  location   String?
  connections String?
  experience String?  // JSON string of experience array
  education  String?  // JSON string of education array
  skills     String?  // JSON string of skills array

  // Analysis results
  lastScore    Int?
  lastAnalysis String?  // JSON string of analysis
  lastSyncedAt DateTime? // When profile was last synced from extension

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, linkedInId]) // One user can have one entry per LinkedIn profile
  @@index([userId])
}

// Post drafts created by AI
model PostDraft {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  topic    String
  content  String
  tone     String
  format   String
  hashtags String?    // JSON string of hashtags array
  status   String     @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// PostStatus values: DRAFT, PUBLISHED, ARCHIVED

// Job match analysis
model JobMatch {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobUrl     String
  jobTitle   String
  company    String
  matchScore Int
  analysis   String   // JSON string of match breakdown

  createdAt DateTime @default(now())

  @@index([userId])
}

// Usage tracking for feature limits
model UsageRecord {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  feature    String // REPLY_SUGGEST, POST_GENERATE, PROFILE_ANALYZE, JOB_MATCH
  tokensUsed Int      @default(0)
  cost       Float    @default(0)

  // Daily/Monthly tracking
  date       DateTime @default(now())

  @@unique([userId, feature, date])
  @@index([userId, date])
}

// Feature values: REPLY_SUGGEST, POST_GENERATE, PROFILE_ANALYZE, JOB_MATCH
